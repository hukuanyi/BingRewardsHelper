{"manifest_version": 3, "name": "Bing Rewards Helper", "version": "1.0.0", "description": "自动完成Bing搜索任务以获取Microsoft Rewards积分，包含每日运行次数检测和限制", "permissions": ["storage", "alarms", "notifications", "tabs"], "host_permissions": ["https://*.bing.com/*", "https://*.rewards.bing.com/*", "https://*.microsoft.com/*", "https://*.live.com/*", "https://*.rewardsplatform.microsoft.com/*"], "background": {"service_worker": "background.js"}, "action": {"default_popup": "popup.html", "default_title": "Bing Rewards Helper"}, "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}, "content_scripts": [{"matches": ["https://login.live.com/oauth20_authorize.srf*"], "js": ["oauth-auto-consent.js"], "run_at": "document_idle"}], "web_accessible_resources": [{"resources": ["icons/*", "auth.html"], "matches": ["https://*.bing.com/*"]}], "oauth2": {"client_id": "0000000040170455", "scopes": ["service::prod.rewardsplatform.microsoft.com::MBI_SSL"]}}
